<!DOCTYPE html>
<html lang="en">
<head>
  <title>Creator Access | BoatSpotMedia</title>
  <%- include('partials-head') %>
</head>
<body>
  <div class="auth-wrap narrow">
    <h1>Request Creator Access</h1>
    <p>Approval is required before you can access the creator panel. Reviews are typically completed within 24 hours if you qualify.</p>
    <% if (success) { %><div class="notice success">Application received.</div><% } %>
    <form method="POST" class="stack">
      <div class="grid2">
        <input name="first_name" placeholder="First name" required />
        <input name="last_name" placeholder="Last name" required />
      </div>
      <input name="company_name" placeholder="Company or brand name" />
      <input name="email" type="email" placeholder="Email" required />
      <input name="instagram" placeholder="Instagram" required />
      <input name="facebook" placeholder="Facebook (optional)" />
      <input name="youtube" placeholder="YouTube (optional)" />
      <textarea name="reason" rows="5" placeholder="Why should we approve your creator access?" required></textarea>
      <button class="button" type="submit">Submit Application</button>
    </form>
  </div>
</body>
</html>
