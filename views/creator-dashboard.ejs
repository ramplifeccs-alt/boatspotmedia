<!DOCTYPE html>
<html lang="en">
<head>
  <title>Creator Panel | BoatSpotMedia</title>
  <%- include('partials-head') %>
</head>
<body>
<div class="panel-layout">
  <aside class="sidebar">
    <div class="brand small">Creator Panel</div>
    <a class="active">Dashboard</a>
    <a>Batches</a>
    <a>Pricing</a>
    <a>Orders</a>
    <a>Settings</a>
    <a href="/creator/logout">Logout</a>
  </aside>
  <main class="panel-main">
    <div class="section-head">
      <h1><%= creator.public_name || creator.public_name %></h1>
      <p>Approved creator account</p>
    </div>
    <div class="stats-row">
      <div class="stat"><strong>2</strong><span>Orders</span></div>
      <div class="stat"><strong>$65</strong><span>Sales</span></div>
      <div class="stat"><strong>Manual + Instant</strong><span>Delivery types</span></div>
    </div>
    <section class="table-wrap">
      <h2>Orders</h2>
      <table>
        <thead><tr><th>Buyer</th><th>Package</th><th>Status</th><th>Source file</th><th>Date / Time</th><th>Location</th></tr></thead>
        <tbody>
          <% orders.forEach(order => { %>
            <tr>
              <td><%= order.buyer_name %><br><span class="muted small"><%= order.buyer_email %></span></td>
              <td><%= order.package_name %><br><span class="muted small"><%= order.delivery_type %></span></td>
              <td><span class="badge <%= order.status.includes('Pending') ? 'warn' : 'ok' %>"><%= order.status %></span></td>
              <td><%= order.source_file %><br><span class="muted small"><%= order.batch_name %></span></td>
              <td><%= order.video_date %><br><span class="muted small"><%= order.video_time %></span></td>
              <td><%= order.location %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</div>
</body>
</html>
